# ─── AI Provider Keys ────────────────────────────────────────
# At least one key is required for AI generation mode.

# OpenRouter (recommended — access to Gemini, DeepSeek, Claude)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini (direct, free tier available)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Anthropic Claude (optional, used if you add claude routes)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
